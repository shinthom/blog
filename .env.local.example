# --- Supabase ---
# Public URL of the Supabase project.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# Browser-safe publishable key (anon equivalent). Used for public reads.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Server-only: direct Postgres connection used by admin API routes.
# Use the transaction pooler URL (port 6543) for serverless deploys.
# Example: postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=

# --- Cloudflare Images ---
# Hash that appears in the delivery URL: https://imagedelivery.net/{HASH}/<image_id>/<variant>
NEXT_PUBLIC_CLOUDFLARE_IMAGES_HASH=
# API token with "Cloudflare Images:Edit" permission.
CLOUDFLARE_IMAGES_TOKEN=
# 32-character hex account ID (Cloudflare dashboard → right sidebar → "Account ID").
CLOUDFLARE_ACCOUNT_ID=

# --- Admin gating ---
# Comma-separated client IPs (or CIDRs) that see the Write/Drafts menu link.
# Leave empty to never show the link (the routes themselves stay accessible by URL).
ADMIN_ALLOW_IPS=
